# infra/env.production.example
# =============================================================================
# Production environment variable reference.
#
# HOW SECRETS ARE HANDLED:
#   - App secrets (DATABASE_URL, DEEPSEEK_API_KEY, ADMIN_TOKEN) live in
#     GCP Secret Manager. They are NEVER stored in this file, in .env files,
#     or baked into Docker images.
#   - Cloud Run injects them as env vars at container startup via:
#       --set-secrets=DATABASE_URL=DATABASE_URL:latest
#   - CI/CD credentials use Workload Identity Federation (no SA key files).
#
# This file documents what must exist before deploying. It is safe to commit.
# =============================================================================

# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=portfolio-prod-XXXXX
GCP_REGION=us-central1

# ── Cloud Build substitutions (set in trigger, not in code) ──────────────────
_REGION=us-central1
_ARTIFACT_REPO=portfolio-images
_CLOUD_SQL_CONN=portfolio-prod-XXXXX:us-central1:portfolio-db
_SA_EMAIL=portfolio-cloudrun-sa@portfolio-prod-XXXXX.iam.gserviceaccount.com
_BACKEND_SVC=portfolio-backend
_FRONTEND_SVC=portfolio-frontend

# ── GitHub Actions secrets (Settings → Secrets → Actions) ────────────────────

# GCP project ID
GCP_PROJECT_ID=portfolio-prod-XXXXX

# GCP region
GCP_REGION=us-central1

# Workload Identity Federation provider resource name (no SA key needed)
# Format: projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL/providers/PROVIDER
GCP_WORKLOAD_IDENTITY=projects/123456789/locations/global/workloadIdentityPools/github-actions-pool/providers/github-provider

# Cloud Build service account email
GCP_SERVICE_ACCOUNT=portfolio-cloudbuild-sa@portfolio-prod-XXXXX.iam.gserviceaccount.com

# Cloud SQL connection name
CLOUD_SQL_CONN=portfolio-prod-XXXXX:us-central1:portfolio-db

# ── Secret Manager secrets (create with gcloud, never stored here) ────────────

# PostgreSQL connection via Cloud SQL Unix socket (auto-generated by bootstrap.sh)
# DATABASE_URL=postgresql://portfolio_user:GENERATED@localhost/portfolio?host=/cloudsql/PROJECT:REGION:INSTANCE

# DeepSeek API key
# gcloud secrets create DEEPSEEK_API_KEY --data-file=- <<< "sk-..."
# DEEPSEEK_API_KEY=sk-...

# Admin panel token
# gcloud secrets create ADMIN_TOKEN --data-file=- <<< "$(openssl rand -hex 32)"
# ADMIN_TOKEN=<32-byte hex string>

# ── Frontend runtime env (set directly on Cloud Run service, not secrets) ─────

# Injected automatically by cloudbuild.yaml from the backend Cloud Run URL
# BACKEND_URL=https://portfolio-backend-HASH-uc.a.run.app

# Intentionally empty — client components use the Next.js rewrite proxy
# NEXT_PUBLIC_API_URL=
